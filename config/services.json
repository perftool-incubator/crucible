{
    "cdm-server": {
        "port": 3000
    },
    "httpd": {
        "port": 8080
    },
    "image-sourcing": {
        "use": true,
        "services": {
            "default": {
                "start": true,
                "location": {
                    "address": "localhost",
                    "port": 8888,
                    "protocol": "http"
                }
            }
        }
    },
    "opensearch": {
        "instances": [
            {
                "name": "local-v8",
                "host": "localhost:9200",
                "cdmver": "v8dev"
            },
            {
                "name": "local-v9",
                "host": "localhost:9200",
                "cdmver": "v9dev"
            }
        ],
        "index-to": "local-v9",
        "query-from": [
            "local-v9",
            "local-v8"
        ]
    },
    "remote-archive": {
        "remotes": {
            "test-s3": {
                "type": "s3",
                "credentials": "/root/crucible-internal/s3-creds.json",
                "bucket": "crucible-archives",
                "tls-verify": false,
                "settings": {
                    "endpoint": "http://192.168.12.100:9000",
                    "region": "us-east-1"
                }
            }
        },
        "default": "test-s3"
    },
    "valkey": {
        "monitor": {
            "enabled": false
        }
    }
}
