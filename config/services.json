{
    "cdm-server": {
        "port": 3000
    },
    "httpd": {
        "port": 8080
    },
    "image-sourcing": {
        "use": true,
        "services": {
            "x86_64": {
                "start": true,
                "location": {
                    "address": "localhost",
                    "port": 8888,
                    "protocol": "http"
                }
            }
        }
    },
    "opensearch": {
        "instances": [
            {
                "name": "local-v8",
                "host": "localhost:9200",
                "cdmver": "v8dev"
            },
            {
                "name": "local-v9",
                "host": "localhost:9200",
                "cdmver": "v9dev"
            }
        ],
        "index-to": "local-v9",
        "query-from": [
            "local-v9",
            "local-v8"
        ]
    },
    "valkey": {
        "monitor": {
            "enabled": false
        }
    }
}
