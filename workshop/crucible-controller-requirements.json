{
  "workshop": {
    "schema": {
      "version": "2020.03.02"
    }
  },
  "userenvs": [
    {
      "name": "crucible-controller",
      "requirements": [
        "dnf-config-modify",
        "motd",
        "dnf-tools",
        "core-utils",
        "build-libraries",
        "build-tools",
        "python39",
        "valkey",
        "redis-compat",
        "container-tools",
        "container-tools-config",
        "httpd",
        "opensearch",
        "logging-perl-modules",
        "gh-cli-repo",
        "gh-cli"
      ]
    }
  ],
  "requirements": [
    {
      "name": "dnf-config-modify",
      "type": "manual",
      "manual_info": {
        "commands": [
          "sed -i -e \"s/tsflags=.*/tsflags=/\" /etc/dnf/dnf.conf",
          "for pkg in $(rpm -qa | sort); do echo -e \"\\n**** Reinstalling: ${pkg} ****\\n\"; if ! dnf --assumeyes reinstall --skip-unavailable ${pkg}; then echo -e \"\\nERROR: Failed to reinstall ${pkg}\"; exit 1; fi; done"
        ]
      }
    },
    {
      "name": "core-utils",
      "type": "distro",
      "distro_info": {
        "packages": [
          "man",
          "curl",
          "tar",
          "cpio",
          "xz",
          "gzip",
          "jq",
          "git",
          "cpio",
          "findutils",
          "hostname",
          "iputils",
          "iproute",
          "bind-utils",
          "procps-ng",
          "bc",
          "sshpass",
          "awk"
        ]
      }
    },
    {
      "name": "python39",
      "type": "distro",
      "distro_info": {
        "packages": [
          "python39",
          "python3-pip"
        ]
      }
    },
    {
      "name": "build-libraries",
      "type": "distro",
      "distro_info": {
        "packages": [
          "xz-devel",
          "glibc-langpack-en"
        ]
      }
    },
    {
      "name": "build-tools",
      "type": "distro",
      "distro_info": {
        "packages": [
          "diffutils",
          "gcc",
          "libtool",
          "autoconf",
          "automake",
          "make"
        ]
      }
    },
    {
      "name": "valkey",
      "type": "distro",
      "distro_info": {
        "packages": [
          "valkey"
        ]
      }
    },
    {
      "name": "redis-compat",
      "type": "manual",
      "manual_info": {
        "commands": [
          "ln -s /usr/bin/valkey-server /usr/bin/redis-server",
          "mkdir -pv /var/lib/redis",
          "mkdir -pv /var/log/redis"
        ]
      }
    },
    {
      "name": "container-tools",
      "type": "distro",
      "distro_info": {
        "packages": [
          "podman",
          "fuse-overlayfs"
        ]
      }
    },
    {
      "name": "container-tools-config",
      "type": "manual",
      "manual_info": {
        "commands": [
          "cp /usr/share/containers/storage.conf /etc/containers",
          "sed -i -e 's|#mount_program = \"/usr/bin/fuse-overlayfs\"|mount_program = \"/usr/bin/fuse-overlayfs\"|' /etc/containers/storage.conf"
        ]
      }
    },
    {
      "name": "httpd",
      "type": "distro",
      "distro_info": {
        "packages": [
          "httpd"
        ]
      }
    },
    {
      "name": "opensearch",
      "type": "manual",
      "manual_info": {
        "commands": [
          "if [ \"$(uname -m)\" == 'x86_64' ]; then echo 'Processing x86_64'; curl --output /usr/share/opensearch.tar.gz https://artifacts.opensearch.org/releases/core/opensearch/3.4.0/opensearch-min-3.4.0-linux-x64.tar.gz; else echo 'Not x86_64'; fi",
          "if [ \"$(uname -m)\" == 'aarch64' ]; then echo 'Processing aarch64'; curl --output /usr/share/opensearch.tar.gz https://artifacts.opensearch.org/releases/core/opensearch/3.4.0/opensearch-min-3.4.0-linux-arm64.tar.gz; else echo 'Not aarch64'; fi",
          "tar --directory /usr/share --extract --gunzip --file /usr/share/opensearch.tar.gz",
          "rm --verbose /usr/share/opensearch.tar.gz",
          "ln --symbolic --verbose /usr/share/opensearch-* /usr/share/opensearch",
          "ln --symbolic --verbose /usr/share/opensearch/config /etc/opensearch",
          "sed -i '2i\\sed -i -e \"/plugins.security.disabled/d\" /etc/opensearch/opensearch.yml' /usr/share/opensearch/bin/opensearch",
          "adduser --system --shell /bin/bash --user-group opensearch",
          "usermod --append --groups opensearch opensearch",
          "chown --recursive opensearch:opensearch /usr/share/opensearch*"
        ]
      }
    },
    {
      "name": "logging-perl-modules",
      "type": "distro",
      "distro_info": {
        "packages": [
          "perl-Time-HiRes",
          "perl-DBI",
          "perl-DBD-SQLite",
          "perl-Data-Dumper"
        ]
      }
    },
    {
      "name": "motd",
      "type": "manual",
      "manual_info": {
        "commands": [
          "printf \"Crucible\\n    There is no escape\\n        (unless you press control-D)\\n\\n\\n\" >/etc/motd"
        ]
      }
    },
    {
      "name": "dnf-tools",
      "type": "distro",
      "distro_info": {
        "packages": [
          "\"dnf-command(config-manager)\""
        ]
      }
    },
    {
      "name": "gh-cli-repo",
      "type": "files",
      "files_info": {
        "files": [
          {
            "src": "https://cli.github.com/packages/rpm/gh-cli.repo",
            "dst": "/etc/yum.repos.d/gh-cli.repo"
          }
        ]
      }
    },
    {
      "name": "gh-cli",
      "type": "distro",
      "distro_info": {
        "packages": [
          "gh"
        ]
      }
    }
  ]
}
